<% provide(:title, 'basic_info') %>
<% provide(:class_text, 'basic-info-all') %>
<div class="modal-header">
  <h1 class="modal-title">基本情報編集</h1>
</div>
<div class="modal-body">
  <div class="row">
    <div class="col-md-6 col-md-offset-3">
      <%= form_with(url: update_all_basic_info_users_path, model: @user, local: false, method: :patch) do |f| %>

        <%= f.label :basic_time, class: "label-#{yield(:class_text)}" %>
        <%= f.time_field :basic_time, class: "form-control" %>

        <%= f.label :work_time, class: "label-#{yield(:class_text)}" %>
        <%= f.time_field :work_time, class: "form-control" %>

        <div class="center">
          <%= f.submit "更新", class: "btn btn-primary btn-block" %>
        </div>
      <% end %>
    </div>
  </div>
</div>